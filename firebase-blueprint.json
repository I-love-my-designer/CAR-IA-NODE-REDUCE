{
  "entities": {
    "compositingJob": {
      "title": "Compositing Job",
      "description": "Represents a vehicle compositing request from the mobile app to the studio app.",
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "processing", "completed", "error"]
        },
        "vehicleImage": {
          "type": "string",
          "description": "The cropped vehicle image (Base64)."
        },
        "backgroundId": {
          "type": "string",
          "description": "The ID of the background selected in the mobile app."
        },
        "roughComposite": {
          "type": "string",
          "description": "The rough composition image (Image 01) for reference (Base64)."
        },
        "finalResult": {
          "type": "string",
          "description": "The high-quality final composite generated by AI (Base64 or URL)."
        },
        "studioNotes": {
          "type": "string",
          "description": "Notes from the studio operator."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["status", "createdAt"]
    },
    "exportItem": {
      "title": "Export Item",
      "description": "Represents a high-quality rendering request received and processed in the background.",
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "completed", "failed"]
        },
        "imageA": {
          "type": "string",
          "description": "The background image (Base64 or URL)"
        },
        "imageB": {
          "type": "string",
          "description": "The vehicle cutout (Base64, SVG or URL)"
        },
        "imageC": {
          "type": "string",
          "description": "The positioning reference image (Base64 or URL)"
        },
        "rotation": {
          "type": "number",
          "description": "Rotation in degrees"
        },
        "imageFinal": {
          "type": "string",
          "description": "Sublimated final image (Base64)"
        },
        "errorMessage": {
          "type": "string",
          "description": "Technical error message if failed"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["status"]
    }
  },
  "firestore": {
    "compositing_jobs": {
      "schema": "compositingJob",
      "description": "Workflow for vehicle image processing."
    },
    "exports": {
      "schema": "exportItem",
      "description": "Background worker engine for merging and sublimating vehicle images."
    }
  }
}
